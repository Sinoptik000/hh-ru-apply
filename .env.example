# Каталог для persistent-профиля Chromium (относительно корня проекта или абсолютный путь)
HH_SESSION_DIR=./data/session

# Для apply.mjs: 1 — без окна (после отладки)
# HH_HEADLESS=1

# --- scan-telegram.mjs: вакансии в Telegram ---
# TELEGRAM_BOT_TOKEN=123456:ABC...
# TELEGRAM_CHAT_ID=your_chat_or_channel_id
# HH_KEYWORDS=python,backend
# HH_SCAN_LIMIT=10
# HH_PAUSE_MS=2500
# HH_AREA=1

# --- open-vacancies.mjs: ключи в config/search-keywords.txt или свой файл ---
# HH_KEYWORDS_FILE=./config/search-keywords.txt
# HH_PER_KEYWORD_LIMIT=8
# Лимит вакансий за один запуск (если задан HH_SESSION_LIMIT, он важнее HH_MAX_TOTAL)
# HH_SESSION_LIMIT=7
# HH_MAX_TOTAL=7
# Пауза между открытием вакансий, мс (случайно в диапазоне)
# HH_OPEN_DELAY_MIN_MS=3000
# HH_OPEN_DELAY_MAX_MS=5000
# Джиттер после перехода на страницу поиска, мс
# HH_SEARCH_JITTER_MIN_MS=1000
# HH_SEARCH_JITTER_MAX_MS=2000
# Короткий джиттер после загрузки карточки вакансии, мс
# HH_POST_LOAD_JITTER_MIN_MS=200
# HH_POST_LOAD_JITTER_MAX_MS=800

# --- harvest.mjs + OpenRouter (ключи в config/secrets.local.env, см. config/OPENROUTER.md) ---
# OpenRouter_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=qwen/qwen3.6-plus-preview:free
# (или openrouter/free — маршрутизатор бесплатных моделей)
# OPENROUTER_ALLOW_PAID=1
# DASHBOARD_PORT=3849
