# Скопируйте в config/secrets.local.env (файл в .gitignore).
#
# OpenRouter — оценка вакансий (по умолчанию только бесплатные модели, см. OPENROUTER.md)
# Формат без пробелов вокруг =
# OpenRouter_API_KEY=sk-or-v1-...
#
# Необязательно: модель (по умолчанию в коде — qwen/qwen3.6-plus-preview:free)
# OPENROUTER_MODEL=qwen/qwen3.6-plus-preview:free
# или маршрутизатор: OPENROUTER_MODEL=openrouter/free
# или другой free-id, например: OPENROUTER_MODEL=google/gemma-2-9b-it:free
#
# Только если осознанно нужны платные модели:
# OPENROUTER_ALLOW_PAID=1
# OPENROUTER_MODEL=...
